# ─────────────────────────────────────────────
# Propulsar Content Engine — Variables de entorno
# Copiar este archivo a .env y completar los valores
# NUNCA commitear el .env real al repositorio
# ─────────────────────────────────────────────

# ══════════════════════════════════════════════
# LOCALES — necesarias para correr el Wizard
# ══════════════════════════════════════════════

# n8n — URL del webhook trigger del workflow
# Formato: https://tu-instancia-n8n.com/webhook/propulsar-content-v3
WEBHOOK_URL=

# WhatsApp — numero que recibira las aprobaciones
# Formato: codigo de pais + numero, sin espacios (ej: +34612345678)
WHATSAPP_APPROVAL_NUMBER=

# Anthropic — para sugerencia de angulos en el Wizard
# Obtener en: console.anthropic.com
ANTHROPIC_API_KEY=

# Perplexity — trending topics en tiempo real (OPCIONAL)
# Si no se configura, el Wizard usa temas de respaldo curados
# Obtener en: perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# ══════════════════════════════════════════════
# EN N8N — estas NO van en local
# Se configuran como variables de entorno en el
# servidor/contenedor donde corre n8n
# ══════════════════════════════════════════════
#
# OPENAI_API_KEY        — GPT-4o para generar texto
# FAL_API_KEY           — Flux 2 Pro + Nano Banana Pro (imagenes)
# IDEOGRAM_API_KEY      — Ideogram v3 (texto en imagen)
# YCLOUD_API_KEY        — Envio de WhatsApp
# YCLOUD_WHATSAPP_NUMBER — Numero WA Business
# META_PAGE_TOKEN       — Publicar en Instagram + Facebook
# INSTAGRAM_ACCOUNT_ID  — ID cuenta IG Business
# FACEBOOK_PAGE_ID      — ID pagina de Facebook
# GOOGLE_SHEETS_ID      — Log de publicaciones
# SUPABASE_URL          — Estado entre webhooks
# SUPABASE_ANON_KEY     — Auth Supabase
