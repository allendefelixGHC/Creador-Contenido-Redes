# ─────────────────────────────────────────────
# Propulsar Content Engine — Variables de entorno
# Copiar este archivo a .env y completar los valores
# NUNCA commitear el .env real al repositorio
# ─────────────────────────────────────────────

# n8n — URL del webhook trigger del workflow
# Formato: https://n8n-azure.propulsar.ai/webhook/propulsar-content
WEBHOOK_URL=https://n8n-azure.propulsar.ai/webhook/propulsar-content

# WhatsApp — número que recibirá las aprobaciones
# Formato: código de país + número, sin + ni espacios
# Ejemplo España: 34612345678
# Ejemplo Argentina: 5491112345678
WHATSAPP_APPROVAL_NUMBER=34612345678

# YCloud — para enviar mensajes de WhatsApp
YCLOUD_API_KEY=your_ycloud_api_key_here
YCLOUD_WHATSAPP_NUMBER=your_whatsapp_business_number

# OpenAI — para generación de texto (GPT-4o) y DALL-E 3 (opcional)
OPENAI_API_KEY=sk-your_openai_api_key_here

# ── MÓDULO DE ÁNGULOS ──────────────────────────────────────
# Perplexity — para buscar trending topics en tiempo real
# Plan gratuito alcanza para uso normal: https://www.perplexity.ai/settings/api
# Si no lo configurás, el Wizard usa temas de respaldo curados
PERPLEXITY_API_KEY=pplx-your_key_here

# ── MÓDULO DE IMAGEN PREMIUM ───────────────────────────────
# FAL.AI — para Flux 2 Pro (imagen premium, ~$0.03/img)
# Crear cuenta y API key en: https://fal.ai/dashboard/keys
FAL_API_KEY=your_fal_api_key_here

# Ideogram v3 — para posts con texto/datos en imagen (opcional)
# Crear cuenta en: https://ideogram.ai → API → Generate API Key
IDEOGRAM_API_KEY=your_ideogram_api_key_here

# Meta Graph API — para publicar en Instagram y Facebook
META_PAGE_TOKEN=your_meta_page_access_token
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id
FACEBOOK_PAGE_ID=your_facebook_page_id

# Google Sheets — para el log de publicaciones
# Es el ID en la URL: docs.google.com/spreadsheets/d/[ESTE_ID]/edit
GOOGLE_SHEETS_ID=your_google_sheets_id

# Supabase — para guardar estado entre webhooks (aprobación)
# Necesario para el flujo de aprobación por WhatsApp
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_TABLE_NAME=content_sessions
